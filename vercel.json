{
	"buildCommand": "npm run build",
	"devCommand": "npm run dev",
	"installCommand": "npm install",
	"framework": "nextjs",
	"nodeVersion": "20.x",
	"env": {
		"NEXT_PUBLIC_SITE_URL": {
			"description": "Site URL for canonical links",
			"placeholder": "https://yourdomain.com"
		}
	},
	"functions": {
		"pages/**": {
			"includeFiles": "posts/**"
		}
	}
}